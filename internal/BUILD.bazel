    ],
)

bzl_library(
    name = "vivado_gui",
    srcs = ["vivado_gui.bzl"],
    deps = [
        ":defines",
    ],
)

stardoc(
    name = "md_defines",
    out = "gen.defines.md",
    input = "defines.bzl",
    deps = [":defines"],
)

stardoc(
    name = "md_providers",
    out = "gen.providers.md",
