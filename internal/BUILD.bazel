    deps = [
        ":defines",
        ":providers",
    ],
)

bzl_library(
    name = "vivado_place_and_route2",
    srcs = ["vivado_place_and_route2.bzl"],
    deps = [
        ":defines",
        ":providers",
    ],
)

bzl_library(
    name = "vivado_program_device",
    srcs = ["vivado_program_device.bzl"],
    deps = [
        ":providers",
    ],
)

bzl_library(
    name = "vivado_library",
    srcs = ["vivado_library.bzl"],
    deps = [
        ":defines",
        ":providers",
    ],
