load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "xprgen_lib",
    srcs = [
        "main.go",
        "templates.go",
    ],
    importpath = "cp/build/vivado/bin/xprgen",
    visibility = ["//visibility:private"],
)

go_test(
    name = "xprgen_test",
    srcs = ["main_test.go"],
    embed = [":xprgen_lib"],
)

go_binary(
    name = "xprgen",
    embed = [":xprgen_lib"],
    visibility = ["//visibility:public"],
)
